{
  "name": "aurinko-sdk",
  "version": "1.0.0",
  "description": "Unofficial TypeScript SDK for Aurinko Unified Mailbox APIs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "aurinko",
    "email",
    "calendar",
    "contacts",
    "tasks",
    "unified-api",
    "mailbox",
    "gmail",
    "office365",
    "typescript",
    "sdk"
  ],
  "author": "Kanishka Naik",
  "contributors": [
    {
      "name": "Kanishka Naik"
    }
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iamkanishka/aurinko-sdk.git"
  },
  "homepage": "https://github.com/iamkanishka/aurinko-sdk#readme",
  "bugs": {
    "url": "https://github.com/iamkanishka/aurinko-sdk/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "ts-node": "^10.9.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.57.1"
  }
}
